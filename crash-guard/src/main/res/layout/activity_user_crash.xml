<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!-- Error Icon -->
<!--    <ImageView-->
<!--        android:layout_width="80dp"-->
<!--        android:layout_height="80dp"-->
<!--        android:src="@drawable/ic_error"-->
<!--        android:tint="#F44336"-->
<!--        android:contentDescription="Error icon" />-->

    <!-- Title -->
    <TextView
        android:id="@+id/tv_crash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Oops! Something went wrong"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_crash_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="The app has encountered an unexpected error. We apologize for the inconvenience. Please restart the app to continue."
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_crash_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textSize="12sp"
        android:textColor="#999999" />

    <!-- Buttons -->
    <Button
        android:id="@+id/btn_restart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Restart App"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="#2196F3"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="Close"
        android:textSize="16sp"
        android:textColor="#666666"
        android:background="#E0E0E0"
        android:textAllCaps="false" />

</LinearLayout>