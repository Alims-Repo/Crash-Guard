<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💥 App Crashed"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF5252"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#424242"
            android:layout_marginBottom="16dp" />

        <!-- Exception Type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exception Type:"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_exception_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FF9800"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Exception Message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message:"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_exception_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Device Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device Info:"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_device_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Memory Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Memory &amp; System:"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_memory_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Custom Data -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Data:"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_custom_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Stack Trace -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stack Trace:"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_stack_trace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:background="#2C2C2C" />

        </HorizontalScrollView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_copy_crash"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Copy"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#424242"
                android:layout_marginEnd="4dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_share_crash"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Share"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#424242"
                android:layout_marginStart="4dp"
                android:textAllCaps="false" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_restart_dev"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Restart App"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_close_dev"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Close"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#757575"
            android:textAllCaps="false" />

    </LinearLayout>

</ScrollView>